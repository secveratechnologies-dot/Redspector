datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  domain    String?    @unique
  status    String     @default("Active") // "Active", "Suspended"
  users     User[]
  campaigns Campaign[]
  assets    Asset[]
  findings  Finding[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String
  fullName            String?
  role                String               @default("Viewer")
  mfaVerified         Boolean              @default(false)
  mfaSecret           String?
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Campaign {
  id        String   @id
  name      String
  status    String   @default("Pending")
  progress  Int      @default(0)
  findings  Int      @default(0)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id        String   @id
  name      String
  type      String
  owner     String
  risk      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cves      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Finding {
  id              String   @id
  title           String
  severity        String
  asset           String
  status          String
  owner           String?
  description     String?
  evidence        String?
  recommendations String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Cve {
  cveId       String   @id
  description String
  cvss        Float
  epss        Float
  isKev       Boolean  @default(false)
  mitreAttack String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
